# ─────────────────────────────────────────────────────────────────────────
# PILLAR CRM AUTOMATION — Environment Variables for Vercel
# ─────────────────────────────────────────────────────────────────────────

# GoHighLevel API Credentials (required)
GHL_TOKEN=your_ghl_api_token_here
GHL_LOCATION_ID=your_location_id_here
GHL_PIPELINE_ID=your_pipeline_id_here
GHL_DEFAULT_OWNER=default_owner_email@pillar.co.uk

# Team Member Email Routing (for role-based opportunity assignment)
GHL_FUNDRAISING_OWNER=fundraising-specialist@pillar.co.uk
GHL_OPS_OWNER=ops-specialist@pillar.co.uk
GHL_ENTERPRISE_OWNER=enterprise-team@pillar.co.uk

# Apollo B2B Enrichment API (optional)
APOLLO_API_KEY=your_apollo_api_key_here

# Email Service Integration (optional — for reporting)
SENDGRID_API_KEY=your_sendgrid_key_here
SENDGRID_FROM_EMAIL=crm@pillar.co.uk

# Reporting Recipients
REPORT_DAILY_TO=sales@pillar.co.uk
REPORT_WEEKLY_TO=team@pillar.co.uk,leadership@pillar.co.uk
REPORT_MONTHLY_TO=leadership@pillar.co.uk

# Webhook Security (optional but recommended)
WEBHOOK_SECRET=your_webhook_secret_for_validation
